# ROM files (user must supply their own)
*.sfc
*.smc
*.srm
*.png
*.ppm
*.wav
*.bin
*.rec

# Build output
build/
*.o
*.exe
*.out

# snesrecomp generated output — mechanically derived from the copyrighted ROM
# (one C function per recompiled 65816 routine). We can't distribute this;
# users must supply their own verified ar.sfc and run tools/regen.sh, which
# writes exactly these paths. recomp/*.cfg is fine to keep tracked — it's our
# own hand-written addresses/directives/commentary, not translated ROM code.
src/gen/*.c
src/generated/*.c
src/generated/*.h
recomp/funcs.h

build-trace/
tools/oracle/oracle_trace.jsonl

# IDE
.claude/
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
.venv/
venv/

# Dependencies (cloned repos)
third_party/

# Test artifacts
tests/golden/*.png
tests/replays/*.bin
saves/snapshots/*

# Trace logs (too large for git)
*.trace
*.cdl
*.log
tools/oracle/harte_cache/
build/opcode_diff/
snesref