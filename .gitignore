# ROM files (user must supply their own)
*.sfc
*.smc
*.srm
*.srm.bak
*.png
*.ppm
*.wav
*.bin
*.rec

# Build output
build/
*.o
*.exe
*.out

# snesrecomp generated output — mechanically derived from the copyrighted ROM
# (one C function per recompiled 65816 routine). We can't distribute this;
# users must supply their own verified ar.sfc and run tools/regen.sh, which
# writes exactly these paths. recomp/*.cfg is fine to keep tracked — it's our
# own hand-written addresses/directives/commentary, not translated ROM code.
src/gen/*.c
src/generated/*.c
src/generated/*.h
recomp/funcs.h

build-trace/
tools/oracle/oracle_trace.jsonl

# IDE
.claude/
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
.venv/
venv/

# Dependencies (cloned repos)
third_party/

# Test artifacts
tests/golden/*.png
tests/replays/*.bin

# saves/ is purely runtime output (WRAM/SRAM dumps, snapshots, replays) — the
# runner writes here (src/main.c), nothing reads a committed file from here as
# a build/test fixture. Blanket-ignore rather than chase individual extensions
# (some prior dumps evaded the *.bin/*.srm/*.rec rules above by filename, e.g.
# "save.srm - pre act 1" doesn't literally end in .srm).
saves/*

# Trace logs (too large for git, and derived from running the actual ROM)
*.trace
*.cdl
*.log
*.jsonl
tools/oracle/harte_cache/
build/opcode_diff/
snesref

# Prebuilt libretro cores (e.g. snes9x_libretro.dylib) — platform-specific
# compiled binaries, not something we build or maintain; users fetch their own
# from buildbot.libretro.com per tools/oracle/README.md.
tools/oracle/*.dylib
tools/oracle/*.so
tools/oracle/*.dll