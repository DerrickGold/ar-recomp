{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}"
    },
    { "name": "release", "displayName": "All platform bundles (orchestrator)", "binaryDir": "${sourceDir}/build/orchestrator" },
    { "name": "macos-arm64", "inherits": "base", "displayName": "snesbuild macOS arm64", "cacheVariables": { "SNESBUILD_GOOS": "darwin", "SNESBUILD_GOARCH": "arm64" } },
    { "name": "macos-x86_64", "inherits": "base", "displayName": "snesbuild macOS x86_64", "cacheVariables": { "SNESBUILD_GOOS": "darwin", "SNESBUILD_GOARCH": "amd64" } },
    { "name": "linux-x86_64", "inherits": "base", "displayName": "snesbuild Linux x86_64", "cacheVariables": { "SNESBUILD_GOOS": "linux", "SNESBUILD_GOARCH": "amd64" } },
    { "name": "linux-arm64", "inherits": "base", "displayName": "snesbuild Linux arm64", "cacheVariables": { "SNESBUILD_GOOS": "linux", "SNESBUILD_GOARCH": "arm64" } },
    { "name": "windows-x86_64", "inherits": "base", "displayName": "snesbuild Windows x86_64", "cacheVariables": { "SNESBUILD_GOOS": "windows", "SNESBUILD_GOARCH": "amd64" } },
    { "name": "windows-arm64", "inherits": "base", "displayName": "snesbuild Windows arm64", "cacheVariables": { "SNESBUILD_GOOS": "windows", "SNESBUILD_GOARCH": "arm64" } }
  ],
  "buildPresets": [
    { "name": "macos-arm64", "configurePreset": "macos-arm64" },
    { "name": "macos-x86_64", "configurePreset": "macos-x86_64" },
    { "name": "linux-x86_64", "configurePreset": "linux-x86_64" },
    { "name": "linux-arm64", "configurePreset": "linux-arm64" },
    { "name": "windows-x86_64", "configurePreset": "windows-x86_64" },
    { "name": "windows-arm64", "configurePreset": "windows-arm64" },
    { "name": "release", "configurePreset": "release", "targets": ["release"] }
  ],
  "packagePresets": [
    { "name": "macos-arm64", "configurePreset": "macos-arm64" },
    { "name": "macos-x86_64", "configurePreset": "macos-x86_64" },
    { "name": "linux-x86_64", "configurePreset": "linux-x86_64" },
    { "name": "linux-arm64", "configurePreset": "linux-arm64" },
    { "name": "windows-x86_64", "configurePreset": "windows-x86_64" },
    { "name": "windows-arm64", "configurePreset": "windows-arm64" }
  ],
  "workflowPresets": [
    {
      "name": "package-macos-arm64",
      "steps": [
        { "type": "configure", "name": "macos-arm64" },
        { "type": "build", "name": "macos-arm64" },
        { "type": "package", "name": "macos-arm64" }
      ]
    },
    {
      "name": "package-macos-x86_64",
      "steps": [
        { "type": "configure", "name": "macos-x86_64" },
        { "type": "build", "name": "macos-x86_64" },
        { "type": "package", "name": "macos-x86_64" }
      ]
    },
    {
      "name": "package-linux-x86_64",
      "steps": [
        { "type": "configure", "name": "linux-x86_64" },
        { "type": "build", "name": "linux-x86_64" },
        { "type": "package", "name": "linux-x86_64" }
      ]
    },
    {
      "name": "package-linux-arm64",
      "steps": [
        { "type": "configure", "name": "linux-arm64" },
        { "type": "build", "name": "linux-arm64" },
        { "type": "package", "name": "linux-arm64" }
      ]
    },
    {
      "name": "package-windows-x86_64",
      "steps": [
        { "type": "configure", "name": "windows-x86_64" },
        { "type": "build", "name": "windows-x86_64" },
        { "type": "package", "name": "windows-x86_64" }
      ]
    },
    {
      "name": "package-windows-arm64",
      "steps": [
        { "type": "configure", "name": "windows-arm64" },
        { "type": "build", "name": "windows-arm64" },
        { "type": "package", "name": "windows-arm64" }
      ]
    },
    {
      "name": "release",
      "displayName": "Build every platform bundle into release/",
      "steps": [
        { "type": "configure", "name": "release" },
        { "type": "build", "name": "release" }
      ]
    }
  ]
}
